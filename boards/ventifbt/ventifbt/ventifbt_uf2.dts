/dts-v1/;
#include <nordic/nrf52840_qiaa.dtsi>

//move to dtsi?
&pinctrl {
	i2c0_default: i2c0_default {
		group1 {
			psels = <NRF_PSEL(TWIM_SDA, 0, 2)>, <NRF_PSEL(TWIM_SCL, 1, 15)>;
			bias-disable;
		};
	};


	i2c0_sleep: i2c0_sleep {
		group1 {
			psels = <NRF_PSEL(TWIM_SDA, 0, 2)>, <NRF_PSEL(TWIM_SCL, 1, 15)>;
			bias-disable;
			low-power-enable;
		};
	};

	spi3_default: spi3_default {
		group1 {
			psels = <NRF_PSEL(SPIM_MISO, 0, 8)>,
					<NRF_PSEL(SPIM_MOSI, 0, 4)>,
					<NRF_PSEL(SPIM_SCK, 0, 5)>;
		};
	};

	spi3_sleep: spi3_sleep {
		group1 {
			psels = <NRF_PSEL(SPIM_MISO, 0, 8)>,
					<NRF_PSEL(SPIM_MOSI, 0, 4)>,
					<NRF_PSEL(SPIM_SCK, 0, 5)>;
			low-power-enable;
		};
	};

	pwm0_default: pwm0_default {

		group1 {
			psels = <NRF_PSEL(PWM_OUT0, 0, 20)>, // Red
					<NRF_PSEL(PWM_OUT1, 0, 24)>, // Green
					<NRF_PSEL(PWM_OUT2, 0, 22)>; // Blue
			nordic,invert;
			nordic,drive-mode = <NRF_DRIVE_S0S1>;
		};
	};

	pwm0_sleep: pwm0_sleep {
		group1 {
			psels = <NRF_PSEL(PWM_OUT0, 0, 20)>, // Red
					<NRF_PSEL(PWM_OUT1, 0, 24)>, // Green
					<NRF_PSEL(PWM_OUT2, 0, 22)>; // Blue
			low-power-enable;
			nordic,drive-mode = <NRF_DRIVE_S0S1>;
			bias-pull-up;
		};
	};
};
//end

/ {
	model = "ventifbt_uf2";
	compatible = "ventifbt_uf2";

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,console = &cdc_acm_uart0;
		zephyr,shell-uart = &cdc_acm_uart0;
	};

	pwmleds {
		compatible = "pwm-leds";
		pwm_led0: pwm_led_0 {
			pwms = <&pwm0 0 PWM_MSEC(1) PWM_POLARITY_INVERTED>; // Red
		};
		pwm_led1: pwm_led_1 {
			pwms = <&pwm0 1 PWM_MSEC(1) PWM_POLARITY_INVERTED>; // Green
		};
		pwm_led2: pwm_led_2 {
			pwms = <&pwm0 2 PWM_MSEC(1) PWM_POLARITY_INVERTED>; // Blue
		};
	};

	leds {
		compatible = "gpio-leds";
		led0: led_0 {
			gpios = <&gpio0 22 GPIO_ACTIVE_LOW>; // Red
		};
		led1: led_1 {
			gpios = <&gpio1 0 GPIO_ACTIVE_LOW>; // Green
		};
		led2: led_2 {
			gpios = <&gpio0 24 GPIO_ACTIVE_LOW>; // Blue
		};
	};

	// buttons {
	// 	compatible = "gpio-keys";
	// 	button0: button_0 {
	// 		gpios = <&gpio0 2 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
	// 		label = "Push button switch 0";
	// 	};
	// };

	aliases {
		// sw0 = &button0;
		pwm-led0 = &pwm_led0; // Red
		pwm-led1 = &pwm_led1; // Green
		pwm-led2 = &pwm_led2; // Blue
		led0 = &led0; // Red
		led1 = &led1; // Green
		led2 = &led2; // Blue
	};

	battery-divider {
		compatible = "voltage-divider";
		status = "okay";
		io-channels = <&adc 7>;
		output-ohms = <1000000>;
		full-ohms = <(1000000+1000000)>;
		power-gpios = <&gpio0 31 (GPIO_OPEN_DRAIN|GPIO_ACTIVE_LOW)>;
	};

	zephyr,user {
		int0-gpios = <&gpio0 26 0>;
		// clk-gpios = <&gpio0 4 GPIO_OPEN_DRAIN>;
	};

};

&reg0 {
	status = "okay";
};

&reg1 {
	regulator-initial-mode = <NRF5X_REG_MODE_DCDC>;
};

&adc {
	status = "okay";
};

&gpiote {
	status = "okay";
};

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

&i2c0 {
	compatible = "nordic,nrf-twim";
	status = "okay";
	zephyr,concat-buf-size = <255>;
	zephyr,flash-buf-max-size = <255>;
	clock-frequency = <I2C_BITRATE_FAST>;
	pinctrl-0 = <&i2c0_default>;
	pinctrl-1 = <&i2c0_sleep>;
	pinctrl-names = "default", "sleep";
		mag: mag@0 {
			compatible = "i2c-device";
			label = "mag";
			reg = <0x0>;
		};

};

&pwm0 {
	status = "okay";
	pinctrl-0 = <&pwm0_default>;
	pinctrl-1 = <&pwm0_sleep>;
	pinctrl-names = "default", "sleep";
};

&spi3 {
	compatible = "nordic,nrf-spim";
	status = "okay";
	pinctrl-0 = <&spi3_default>;
	pinctrl-1 = <&spi3_sleep>;
	pinctrl-names = "default", "sleep";
	cs-gpios = <&gpio1 8 GPIO_ACTIVE_LOW>;

	imu_spi: imu_spi@0 {
		compatible = "vnd,spi-device";
		label = "imu-spi";
		reg = <0>;
		spi-max-frequency = <8000000>;
	};
};


zephyr_udc0: &usbd {
	compatible = "nordic,nrf-usbd";
	status = "okay";
	cdc_acm_uart0: cdc_acm_uart0 {
		compatible = "zephyr,cdc-acm-uart";
	};
};

&wdt {
	status = "okay";
};

&cryptocell {
	status = "disabled";
};

&nfct {
	status = "disabled";
};
